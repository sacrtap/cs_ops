# ===========================================
# 内部运营中台客户信息管理与运营系统 - .gitignore
# ===========================================

# ===========================================
# 依赖
# ===========================================
node_modules/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
*.egg-info/
dist/
build/

# ===========================================
# 环境变量和配置
# ===========================================
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json
credentials.json

# ===========================================
# IDE 和编辑器
# ===========================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.sublime-*

# ===========================================
# 测试产物
# ===========================================
# Playwright
playwright-report/
test-results/
blob-report/
.pwtmp/

# pytest
.pytest_cache/
.coverage
coverage/
htmlcov/
.mypy_cache/
.ruff_cache/

# Vitest
coverage.json
coverage-*.json

# JUnit 测试报告
*.xml
!package-lock.xml

# ===========================================
# 日志
# ===========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===========================================
# 上传文件
# ===========================================
storage/
uploads/
temp/
tmp/

# ===========================================
# 数据库
# ===========================================
*.db
*.sqlite
*.sqlite3

# ===========================================
# 构建产物
# ===========================================
# 前端构建
frontend/dist/
frontend/build/

# 后端构建
backend/build/
backend/dist/

# ===========================================
# Docker
# ===========================================
*.log
docker-compose.override.yml

# ===========================================
# 其他
# ===========================================
*.bak
*.tmp
.cache/
.parcel-cache/

# ===========================================
# BMAD Framework
# ===========================================
# BMAD 框架核心 - 需要提交
!_bmad/
!.opencode/

# BMAD 生成输出 - 不提交（除关键文件外）
_bmad-output/*.md
!_bmad-output/project-context.md
!_bmad-output/planning-artifacts/
!_bmad-output/*.csv

# 临时文件
*.local
