# CS Ops Backend Configuration
# Copy this file to .env and update with your values

# ==================== Application ====================
APP_NAME=cs_ops
APP_VERSION=0.1.0
APP_DEBUG=true

# ==================== Database ====================
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cs_ops

# ==================== JWT Configuration ====================
# CRITICAL: Change this in production! Use at least 32 characters
JWT_SECRET_KEY=3fe636e1433b52cb18a010f2355a2ec27c86cae238f1ff67ad04e7c4ae103178

# JWT Algorithm
JWT_ALGORITHM=HS256

# Token expiration times
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== Security ====================
# bcrypt password hashing rounds
BCRYPT_ROUNDS=10

# Login failure limit (lockout after N failed attempts)
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in minutes
LOCKOUT_DURATION_MINUTES=15

# ==================== CORS ====================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ==================== Server ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
