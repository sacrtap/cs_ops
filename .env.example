# ===========================================
# 内部运营中台客户信息管理与运营系统
# 环境配置示例文件
# ===========================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际环境修改配置值
# 3. 切勿将 .env 提交到版本控制
# ===========================================

# ===========================================
# 应用配置
# ===========================================
APP_NAME=cs-ops
APP_ENV=development  # development, staging, production
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production

# ===========================================
# 服务器配置
# ===========================================
# 前端开发服务器
BASE_URL=http://localhost:3000
FRONTEND_PORT=3000

# 后端 API 服务器
API_URL=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ===========================================
# 数据库配置 (PostgreSQL 18)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cs_ops
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# 测试数据库配置
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=cs_ops_test
TEST_DB_USER=postgres
TEST_DB_PASSWORD=your-password-here

# ===========================================
# Redis 配置 (Celery 任务队列)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_ACCEPT_CONTENT=[json]
CELERY_TIMEZONE=Asia/Shanghai

# ===========================================
# JWT 认证配置
# ===========================================
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# 测试配置
# ===========================================
TEST_ENV=test
TEST_BASE_URL=http://localhost:3000
TEST_API_URL=http://localhost:8000
TEST_BROWSER=headless  # headless, headed
TEST_TIMEOUT=60000

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json, text
LOG_FILE=logs/app.log

# ===========================================
# 文件存储配置
# ===========================================
STORAGE_TYPE=local  # local, s3
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=xlsx,csv,pdf

# ===========================================
# 第三方服务配置（可选）
# ===========================================
# AWS S3 配置（如使用 S3 存储）
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET_NAME=
# AWS_REGION=us-east-1

# 邮件服务配置
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=noreply@example.com

# ===========================================
# 功能开关（Feature Flags）
# ===========================================
ENABLE_CUSTOMER_IMPORT=true
ENABLE_BULK_EXPORT=true
ENABLE_HEALTH_MONITORING=true
ENABLE_VALUE_ASSESSMENT=true
ENABLE_BILLING_ENGINE=true
ENABLE_DATA_ANALYTICS=true

# ===========================================
# 性能配置
# ===========================================
CACHE_TTL=3600  # 缓存过期时间（秒）
RATE_LIMIT_PER_MINUTE=100
BATCH_SIZE=1000  # 批量操作默认大小
API_RATE_LIMIT=1000  # API 每分钟请求限制
